<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MTG Glamify Converter</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

        <!-- Custom purple overrides -->
    <style>
        .bg-purple {
            background-color: #6f42c1 !important; /* Bootstrap purple */
        }
        
        .bg-dim-purple {
            background-color: #f2ecff !important; /* Bootstrap purple */
        }
        .btn-outline-purple {
            color: #6f42c1;
            border-color: #6f42c1;
        }
        .btn-outline-purple:hover {
            background-color: #6f42c1;
            color: #fff;
        }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">
    <!-- Header -->
    <header class="bg-purple text-white py-3 mb-4">
        <div class="container">
            <h1 class="h3 mb-0">✨ MTG Glamify</h1>
        </div>
    </header>

    <!-- Main Content -->
    <main class="container flex-grow-1">
        <form action="/convert" method="POST">
            <div class="bg-dim-purple p-3 rounded border mb-4">
                <h5 class="fw-bold mb-3">Parameters</h5>
                
                <!-- Basic Land Set row -->
                <div class="d-flex align-items-center mb-3">
                    <span class="me-2">Basic Land Set:</span>
                    <select class="form-select w-auto" id="landSet" name="landSet">
                        <option value="Coming soon">Coming soon</option>
                    </select>
                </div>

                <!-- Prioritise Full art row -->
                <div class="d-flex align-items-center">
                    <span class="me-2">Prioritise Full art</span>
                    <input type="checkbox" class="form-check-input" disabled checked>
                </div>
            </div>
            <!-- Input / Button / Output row -->
            <div class="row g-3">
                <!-- Left: input textarea -->
                <div class="col-md-5">
                    <label for="inputText" class="form-label fw-bold">Your Decklist:</label>
                    <textarea class="form-control" id="inputText" name="inputText" rows="12" placeholder="Enter text to glamify..."><%= inputText %></textarea>
                </div>

                <!-- Center: Glamify button (styled as an arrow) -->
                <div class="col-md-2 d-flex align-items-center justify-content-center">
                    <button type="submit" class="btn btn-lg btn-outline-purple rounded-pill px-4">
                        Glamify <span class="ms-1">→</span>
                    </button>
                </div>

                <!-- Right: output textarea (readonly) -->
                <div class="col-md-5">
                    <label for="outputText" class="form-label fw-bold">✨Glamified Decklist:</label>
                    <textarea class="form-control" id="outputText" rows="12" readonly placeholder="Your glamified text will appear here..."><%= outputText %></textarea>
                </div>
            </div>
        </form>
    </main>

    <!-- Footer -->
    <footer class="bg-light text-center py-3 mt-5">
        <div class="container">
            <small class="text-muted">Made by Henry</small>
        </div>
    </footer>

    <!-- Optional Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>